# ===== LiveKit =====
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>

# ===== Agent =====
# Agent name for explicit dispatch (leave blank for automatic dispatch)
AGENT_NAME=pipeline-agent
ROOM_NAME=english-practice
# Run one worker per mode:
#   AGENT_WORKER_MODE=pipeline -> pipeline-agent
#   AGENT_WORKER_MODE=realtime AGENT_ROLE=dominant -> realtime-agent
#   AGENT_WORKER_MODE=realtime AGENT_ROLE=collaborative -> realtime-agent
AGENT_WORKER_MODE=pipeline
AGENT_ROLE=dominant

# ===== AI Models (agent/main.py에서 사용) =====
OPENAI_API_KEY=<your_openai_api_key>
DEEPGRAM_API_KEY=<your_deepgram_api_key>

# ===== Class Operation Mode =====
# Production runtime settings are stored in Supabase app_settings and managed from /admin.
# config.json is used only as a local development fallback/import source.
# "pipeline": 그룹 대화 모드, "realtime": 개별 대화 모드

# ===== Next.js Client (client/.env.local에만 필요한 경우) =====
# Deprecated: ADMIN_USERNAME / ADMIN_PASSWORD are no longer used for admin auth.
# NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
# SANDBOX_ID=

# ===== Supabase (admin auth + persistent state + realtime prompt versions) =====
# Browser-safe values. Required in client/.env.local for Next.js:
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Local Supabase CLI URL for this repo: http://127.0.0.1:55321
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
#
# Server-only values. Required in client/.env.local for Next.js API routes.
# Never expose this to browser/client bundles.
# SUPABASE_SECRET_KEY=sb_secret_...
# STUDENT_SESSION_SECRET=<long_random_secret>
# CONVERSATION_LOG_FILE_FALLBACK=false
#
# Python agent can read Supabase from root .env. Use either these explicit names
# or the NEXT_PUBLIC_SUPABASE_URL / SUPABASE_SECRET_KEY pair above.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# AWS S3 예시 (위 대신)
# AWS_ACCESS_KEY=AKIA...
# AWS_SECRET_ACCESS_KEY
# S3_BUCKET=cscl-tblt-recordings
# S3_REGION=ap-northeast-2
# S3_ENDPOINT=  ← AWS는 비워두면 됨
